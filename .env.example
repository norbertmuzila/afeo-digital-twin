# WAFEO API Environment Variables
# Copy this file to .env and fill in your values before running locally

# JWT Secret — change this to a long random string in production
JWT_SECRET=wafeo-super-secret-change-me-in-production-2024

# Google OAuth Client ID
GOOGLE_CLIENT_ID=your-google-client-id.apps.googleusercontent.com

# Port (Railway sets this automatically)
PORT=3000
